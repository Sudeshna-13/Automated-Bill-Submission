  );
}

// ── Bill Tracker ──────────────────────────────────────────────
function BillTracker({ bill, S, C }) {
  if (!bill) return null;
  const allSteps = [{ key:"submitted", label:"Submitted", role:null, icon:"📤" }, ...bill.approvalChain.map(r=>({ key:r, label:ROLE_LABEL[r], role:r, icon:r==="accounts"?"🏦":r==="manager"?"👔":"🏛️" }))];
  const getState = (step, idx) => {
    if (step.key==="submitted") return "done";
    const ci=idx-1;
    if (bill.status==="approved") return "done";
    if (bill.status==="rejected") { if(ci<bill.currentStep) return "done"; if(ci===bill.currentStep) return "rejected"; return "waiting"; }
    if (ci<bill.currentStep) return "done"; if (ci===bill.currentStep) return "current"; return "waiting";
  };
  const rejEntry = bill.timeline.find(t=>t.action==="rejected");
  const approvals = bill.timeline.filter(t=>t.action==="approved"||t.action==="final_approved");
  const sc = s => s==="done"?C.green:s==="current"?C.gold:s==="rejected"?C.red:C.border;
  const sb = s => s==="done"?`${C.green}18`:s==="current"?`${C.gold}14`:s==="rejected"?`${C.red}14`:C.faint;
  const si = (s,icon) => s==="done"?"✓":s==="rejected"?"✗":s==="current"?"…":icon;
  const statusLabel = bill.status==="approved"?"✅ Fully Approved":bill.status==="rejected"?"❌ Rejected":`⏳ Awaiting ${ROLE_LABEL[bill.approvalChain[bill.currentStep]]}`;
  const statusColor = bill.status==="approved"?C.green:bill.status==="rejected"?C.red:C.gold;

  return (
    <div style={{background:C.surface,border:`1px solid ${C.border}`,borderRadius:"4px",padding:"24px",marginBottom:"24px"}}>
      <div style={{display:"flex",alignItems:"center",justifyContent:"space-between",marginBottom:"20px"}}>
        <h3 style={{color:C.gold,fontSize:"12px",letterSpacing:".1em",textTransform:"uppercase",margin:0}}>📍 Bill Journey Tracker</h3>
        <span style={{fontSize:"13px",fontWeight:"600",color:statusColor}}>{statusLabel}</span>
      </div>
      <div style={{display:"flex",alignItems:"flex-start",overflowX:"auto",paddingBottom:"8px"}}>
        {allSteps.map((step,idx)=>{
          const state=getState(step,idx);
          const appr=approvals.find(a=>a.role===step.role);
          const isLast=idx===allSteps.length-1;
          return (
            <div key={step.key} style={{display:"flex",alignItems:"flex-start",flex:isLast?"0 0 auto":"1",minWidth:"100px"}}>
              <div style={{display:"flex",flexDirection:"column",alignItems:"center",flex:"0 0 auto",minWidth:"90px"}}>
                <div style={{width:"48px",height:"48px",borderRadius:"50%",background:sb(state),border:`2px solid ${sc(state)}`,display:"flex",alignItems:"center",justifyContent:"center",fontSize:"18px",color:sc(state),fontWeight:"700",boxShadow:state==="current"?`0 0 12px ${C.gold}40`:"none"}}>
                  {si(state,step.icon)}
                </div>
                <div style={{fontSize:"11px",color:state==="waiting"?C.muted:sc(state),textAlign:"center",marginTop:"8px",fontWeight:state==="current"?"700":"400",maxWidth:"90px"}}>{step.label}</div>
                {state==="done"&&appr&&<div style={{fontSize:"10px",color:C.muted,textAlign:"center",marginTop:"3px"}}>{new Date(appr.timestamp).toLocaleDateString("en-IN",{day:"2-digit",month:"short"})}</div>}
                {state==="done"&&step.key==="submitted"&&<div style={{fontSize:"10px",color:C.muted,textAlign:"center",marginTop:"3px"}}>{new Date(bill.createdAt).toLocaleDateString("en-IN",{day:"2-digit",month:"short"})}</div>}
                {state==="current"&&<div style={{fontSize:"10px",color:C.gold,textAlign:"center",marginTop:"3px"}}>Awaiting action</div>}
                {state==="rejected"&&<div style={{fontSize:"10px",color:C.red,textAlign:"center",marginTop:"3px"}}>Rejected here</div>}
                {state==="waiting"&&<div style={{fontSize:"10px",color:C.muted,textAlign:"center",marginTop:"3px"}}>Not yet reached</div>}
              </div>
              {!isLast&&<div style={{flex:1,height:"2px",marginTop:"23px",background:state==="done"?C.green:C.border,minWidth:"20px"}} />}
            </div>
          );
        })}
      </div>
      {bill.status==="rejected"&&rejEntry&&(
        <div style={{marginTop:"20px",background:`${C.red}10`,border:`1px solid ${C.red}40`,borderRadius:"3px",padding:"14px 16px"}}>
          <div style={{fontSize:"12px",color:C.red,fontWeight:"700",letterSpacing:".06em",textTransform:"uppercase",marginBottom:"6px"}}>❌ Rejected by {rejEntry.by}</div>
          <div style={{fontSize:"13px",color:C.text,marginBottom:"4px"}}><strong>Reason:</strong> {rejEntry.comment}</div>
          <div style={{fontSize:"11px",color:C.muted}}>{new Date(rejEntry.timestamp).toLocaleString("en-IN",{day:"2-digit",month:"short",year:"numeric",hour:"2-digit",minute:"2-digit"})}</div>
        </div>
      )}
      {bill.status==="approved"&&(
        <div style={{marginTop:"20px",background:`${C.green}10`,border:`1px solid ${C.green}40`,borderRadius:"3px",padding:"14px 16px"}}>
          <div style={{fontSize:"12px",color:C.green,fontWeight:"700",marginBottom:"4px"}}>🎉 Bill Fully Sanctioned</div>
          <div style={{fontSize:"13px",color:C.text}}>All {bill.approvalChain.length} level{bill.approvalChain.length>1?"s":""} completed. ₹{parseFloat(bill.amount).toLocaleString("en-IN")} cleared for payment.</div>
        </div>
      )}
      {bill.status==="pending"&&(
        <div style={{marginTop:"20px",background:`${C.gold}08`,border:`1px solid ${C.gold}30`,borderRadius:"3px",padding:"14px 16px",display:"flex",alignItems:"center",gap:"12px"}}>
          <div style={{fontSize:"22px"}}>⏳</div>
          <div>
            <div style={{fontSize:"13px",color:C.gold,fontWeight:"600",marginBottom:"2px"}}>Currently with: {ROLE_LABEL[bill.approvalChain[bill.currentStep]]}</div>
            <div style={{fontSize:"12px",color:C.muted}}>Step {bill.currentStep+1} of {bill.approvalChain.length}</div>
          </div>
        </div>
      )}
    </div>
  );
}

// ── Bill Detail ───────────────────────────────────────────────
function BillDetail({ billId, user, onBack, onUpdate, S, C }) {
  const [bill, setBill] = useState(null);
  const [comment, setComment] = useState("");
  const [rejectNote, setRejectNote] = useState("");
  const [showModal, setShowModal] = useState(false);

  const load = () => setBill(getBills().find(x=>x.id===billId)||null);
  useEffect(()=>{ load(); },[billId]);

  if (!bill) return <div style={{color:C.muted,padding:"40px"}}>Loading…</div>;

  const currentRole = bill.approvalChain[bill.currentStep];
  const canAct = user.role===currentRole && bill.status==="pending";

  const doApprove = () => {
    const bills=getBills(), idx=bills.findIndex(b=>b.id===billId);
    if (idx<0) return;
    const b={...bills[idx],timeline:[...bills[idx].timeline]};
    b.timeline.push({action:"approved",by:user.name,role:user.role,timestamp:new Date().toISOString(),comment:comment.trim()||`Approved by ${user.name} (${ROLE_LABEL[user.role]})`});
    const last=b.currentStep>=b.approvalChain.length-1;
    if (last) {
      b.status="approved";
      b.timeline.push({action:"final_approved",by:"System",role:"system",timestamp:new Date(Date.now()+50).toISOString(),comment:"All approval levels completed. Bill is fully sanctioned."});
      pushN(b.submittedBy,`🎉 Your bill ${b.id} (₹${parseFloat(b.amount).toLocaleString("en-IN")} | ${b.vendor}) has been FULLY APPROVED.`,b.id,true);
    } else {
      b.currentStep+=1;
      const next=b.approvalChain[b.currentStep];
      pushN(next,`✅ Bill ${b.id} approved by ${ROLE_LABEL[user.role]}. Requires your approval now.`,b.id);
      pushN(b.submittedBy,`✅ Your bill ${b.id} was approved by ${ROLE_LABEL[user.role]}. Now awaiting ${ROLE_LABEL[next]}.`,b.id,true);
    }
    bills[idx]=b; saveBills(bills); setComment(""); setBill(b); onUpdate();
  };

  const doReject = () => {
    if (!rejectNote.trim()) return;
    const bills=getBills(), idx=bills.findIndex(b=>b.id===billId);
    if (idx<0) return;
    const b={...bills[idx],timeline:[...bills[idx].timeline]};
    b.status="rejected";
    b.timeline.push({action:"rejected",by:user.name,role:user.role,timestamp:new Date().toISOString(),comment:rejectNote.trim()});
    pushN(b.submittedBy,`❌ Your bill ${b.id} was REJECTED by ${ROLE_LABEL[user.role]}: "${rejectNote.trim()}"`,b.id,true);
    bills[idx]=b; saveBills(bills); setShowModal(false); setRejectNote(""); setBill(b); onUpdate();
  };

  const aColor = a => a.includes("approved")?C.green:a==="rejected"?C.red:a==="submitted"?C.gold:C.muted;
  const aIcon  = a => a.includes("approved")?"✅":a==="rejected"?"❌":a==="submitted"?"📤":"ℹ️";
  const sc     = s => s==="approved"?"green":s==="rejected"?"red":"gold";

  return (
    <div>
      <button style={{...S.btnSm(""),marginBottom:"20px"}} onClick={onBack}>← Back to Bills</button>
      <div style={{display:"flex",alignItems:"center",gap:"14px",marginBottom:"28px",flexWrap:"wrap"}}>
        <div>
          <h1 style={{...S.pageTitle,margin:0}}>{bill.vendor}</h1>
          <p style={{color:C.muted,fontFamily:"monospace",fontSize:"13px",margin:"4px 0 0"}}>{bill.id}</p>
        </div>
        <span style={S.badge(sc(bill.status))}>{bill.status}</span>
        <span style={S.badge("")}>{bill.category}</span>
        <span style={{marginLeft:"auto",fontSize:"24px",fontWeight:"700",color:C.gold}}>₹{parseFloat(bill.amount).toLocaleString("en-IN")}</span>
      </div>
      <BillTracker bill={bill} S={S} C={C} />
      <div style={{display:"grid",gridTemplateColumns:"1fr 1fr",gap:"24px"}}>
        <div style={{display:"flex",flexDirection:"column",gap:"20px"}}>
          <div style={S.card}>
            <h3 style={{color:C.gold,fontSize:"12px",letterSpacing:".1em",marginBottom:"14px"}}>BILL DOCUMENT</h3>
            {bill.imagePreview ? <img src={bill.imagePreview} alt="bill" style={{width:"100%",borderRadius:"3px",maxHeight:"300px",objectFit:"contain",background:C.bg}} /> : <div style={{...S.zone,cursor:"default",color:C.muted}}>No preview</div>}
            {bill.fileName && <p style={{fontSize:"11px",color:C.muted,marginTop:"8px"}}>📁 {bill.fileName}</p>}
          </div>
          <div style={S.card}>
            <h3 style={{color:C.gold,fontSize:"12px",letterSpacing:".1em",marginBottom:"14px"}}>BILL INFORMATION</h3>
            {[["Amount",`₹${parseFloat(bill.amount).toLocaleString("en-IN")}`],["Vendor",bill.vendor],["Date",bill.date],["Category",bill.category],["Invoice No.",bill.invoiceNo||"—"],["GST No.",bill.gst||"—"],["Submitted By",`${bill.submittedByName} (${bill.submittedByCompany})`],["OCR Confidence",bill.ocrConfidence],["Notes",bill.notes||"—"]].map(([k,v])=>(
              <div key={k} style={{display:"flex",justifyContent:"space-between",padding:"8px 0",borderBottom:`1px solid ${C.statBorder}`}}>
                <span style={{color:C.muted,fontSize:"13px"}}>{k}</span>
                <span style={{color:C.text,fontSize:"13px",textAlign:"right",maxWidth:"58%"}}>{v}</span>
              </div>
            ))}
          </div>
        </div>
        <div style={{display:"flex",flexDirection:"column",gap:"20px"}}>
          <div style={S.card}>
            <h3 style={{color:C.gold,fontSize:"12px",letterSpacing:".1em",marginBottom:"18px"}}>APPROVAL WORKFLOW</h3>
            <div style={{display:"flex",alignItems:"center",gap:"6px",marginBottom:"24px",flexWrap:"wrap"}}>
              {bill.approvalChain.map((role,i)=>{
                const done=bill.status==="approved"||i<bill.currentStep;
                const cur=i===bill.currentStep&&bill.status==="pending";
                const rej=bill.status==="rejected"&&i===bill.currentStep;
                return (
                  <div key={role} style={{display:"flex",alignItems:"center",gap:"6px"}}>
                    <div style={{textAlign:"center"}}>
                      <div style={{width:"42px",height:"42px",borderRadius:"50%",display:"flex",alignItems:"center",justifyContent:"center",fontSize:"16px",background:done?`${C.green}20`:cur?`${C.gold}18`:rej?`${C.red}18`:C.faint,border:`2px solid ${done?C.green:cur?C.gold:rej?C.red:C.border}`}}>
                        {done?"✓":rej?"✗":cur?"…":"○"}
                      </div>
                      <div style={{fontSize:"10px",color:C.muted,textTransform:"uppercase",marginTop:"4px"}}>{ROLE_LABEL[role]}</div>
                    </div>
                    {i<bill.approvalChain.length-1&&<div style={{width:"28px",height:"1px",background:done?C.green:C.border,marginBottom:"16px"}} />}
                  </div>
                );
              })}
            </div>
            {canAct && (
              <div>
                <label style={S.label}>Approval Comment (optional)</label>
                <textarea style={{...S.input,minHeight:"72px",resize:"vertical",marginBottom:"12px"}} value={comment} onChange={e=>setComment(e.target.value)} placeholder="Add a note…" />
                <div style={{display:"flex",gap:"10px"}}>
                  <button style={{...S.btnSm("green"),flex:1,padding:"13px",fontSize:"13px"}} onClick={doApprove}>✅ Approve</button>
                  <button style={{...S.btnSm("red"),  flex:1,padding:"13px",fontSize:"13px"}} onClick={()=>setShowModal(true)}>❌ Reject</button>
                </div>
              </div>
            )}
            {!canAct&&bill.status==="pending"&&<div style={S.alert("info")}>⏳ Awaiting <strong>{ROLE_LABEL[currentRole]}</strong>.{user.role!==currentRole&&` You will be notified when it reaches your stage.`}</div>}
            {bill.status==="approved"&&<div style={S.alert("success")}>🎉 Fully approved through all required levels.</div>}
            {bill.status==="rejected"&&<div style={S.alert("error")}>❌ Rejected. See audit trail for reason.</div>}
          </div>
          <div style={S.card}>
            <h3 style={{color:C.gold,fontSize:"12px",letterSpacing:".1em",marginBottom:"18px"}}>AUDIT TRAIL</h3>
            <div style={{position:"relative"}}>
              {bill.timeline.map((e,i)=>(
                <div key={i} style={{position:"relative",paddingLeft:"26px",paddingBottom:i<bill.timeline.length-1?"20px":0}}>
                  {i<bill.timeline.length-1&&<div style={{position:"absolute",left:"8px",top:"14px",bottom:0,width:"1px",background:C.border}} />}
                  <div style={{position:"absolute",left:"2px",top:"3px",width:"12px",height:"12px",borderRadius:"50%",background:aColor(e.action)}} />
                  <div style={{fontSize:"11px",color:aColor(e.action),textTransform:"uppercase",letterSpacing:".07em",marginBottom:"2px"}}>{aIcon(e.action)} {e.action.replace(/_/g," ")}</div>
                  <div style={{fontSize:"13px",color:C.text,marginBottom:"3px"}}>{e.comment}</div>
                  <div style={{fontSize:"11px",color:C.muted}}>{e.by!=="System"?`${e.by} · ${ROLE_LABEL[e.role]||e.role} · `:"System · "}{new Date(e.timestamp).toLocaleString("en-IN",{day:"2-digit",month:"short",year:"numeric",hour:"2-digit",minute:"2-digit"})}</div>
                </div>
              ))}
            </div>
          </div>
        </div>
      </div>
      {showModal && (
        <div style={S.modal} onClick={()=>setShowModal(false)}>
          <div style={S.modalCard} onClick={e=>e.stopPropagation()}>
            <h3 style={{color:C.red,marginBottom:"10px"}}>❌ Reject This Bill</h3>
            <p style={{color:C.muted,fontSize:"14px",marginBottom:"20px"}}>A rejection reason is <strong>mandatory</strong> and will be permanently recorded.</p>
            <label style={S.label}>Rejection Reason *</label>
            <textarea style={{...S.input,minHeight:"110px",marginBottom:"16px"}} value={rejectNote} onChange={e=>setRejectNote(e.target.value)} placeholder="e.g. Duplicate bill. Amount exceeds policy limit. GST invoice missing." />
            {!rejectNote.trim()&&<div style={S.alert("error")}>Reason is required before you can reject.</div>}
            <div style={{display:"flex",gap:"10px"}}>
              <button style={{...S.btnSm("red"),flex:1,padding:"12px"}} onClick={doReject}>Confirm Rejection</button>
              <button style={{...S.btnSm(""),   flex:1,padding:"12px"}} onClick={()=>setShowModal(false)}>Cancel</button>
            </div>
          </div>
        </div>
      )}
    </div>
  );
}

// ── Dashboard ─────────────────────────────────────────────────
function Dashboard({ user, onNavigate, refreshKey, S, C }) {
  const [bills, setBills] = useState([]);
  useEffect(()=>{ const all=getBills(); setBills(["client","supplier"].includes(user.role)?all.filter(b=>b.submittedBy===user.id):all); },[user,refreshKey]);

  const pending=bills.filter(b=>b.status==="pending"), approved=bills.filter(b=>b.status==="approved"), rejected=bills.filter(b=>b.status==="rejected");
  const myQueue=bills.filter(b=>b.status==="pending"&&b.approvalChain[b.currentStep]===user.role);

  return (
    <div>
      <h1 style={S.pageTitle}>Welcome, {user.name}</h1>
      <p style={S.pageSub}>{user.company} · <span style={S.badge("gold")}>{user.role}</span></p>
      <div style={{display:"grid",gridTemplateColumns:"repeat(4,1fr)",gap:"16px",marginBottom:"28px"}}>
        {[["Total",bills.length,C.gold],["Pending",pending.length,C.gold],["Approved",approved.length,C.green],["Rejected",rejected.length,C.red]].map(([l,v,c])=>(
          <div key={l} style={S.statCard(c)}><div style={S.statNum}>{v}</div><div style={S.statLbl}>{l}</div></div>
        ))}
      </div>
      {myQueue.length>0&&(
        <div style={{...S.alert("warn"),fontSize:"14px",marginBottom:"24px"}}>
          🔔 <strong>{myQueue.length}</strong> bill(s) awaiting your approval as <strong>{ROLE_LABEL[user.role]}</strong>.
          <button style={{...S.btnSm("gold"),marginLeft:"12px",padding:"4px 14px"}} onClick={()=>onNavigate("bills")}>Review Now</button>
        </div>
      )}
      <div style={{display:"grid",gridTemplateColumns:"1fr 1fr",gap:"24px"}}>
        <div style={S.card}>
          <h3 style={{color:C.gold,fontSize:"12px",letterSpacing:".1em",marginBottom:"16px"}}>RECENT BILLS</h3>
          {bills.slice(0,6).length===0
            ? <p style={{color:C.muted,fontSize:"14px"}}>No bills yet. <button style={{...S.btnSm("gold"),padding:"4px 12px"}} onClick={()=>onNavigate("upload")}>Upload now</button></p>
            : bills.slice(0,6).map(b=>(
              <div key={b.id} style={{display:"flex",justifyContent:"space-between",alignItems:"center",padding:"10px 0",borderBottom:`1px solid ${C.statBorder}`}}>
                <div><div style={{fontSize:"14px"}}>{b.vendor}</div><div style={{fontSize:"11px",color:C.muted}}>{b.category} · {b.date}</div></div>
                <div style={{textAlign:"right"}}>
                  <div style={{fontWeight:"700",fontSize:"14px"}}>₹{parseFloat(b.amount).toLocaleString("en-IN")}</div>
                  <span style={S.badge(b.status==="approved"?"green":b.status==="rejected"?"red":"gold")}>{b.status}</span>
                </div>
              </div>
            ))
          }
        </div>
        <div style={S.card}>
          <h3 style={{color:C.gold,fontSize:"12px",letterSpacing:".1em",marginBottom:"16px"}}>QUICK ACTIONS</h3>
          <div style={{display:"flex",flexDirection:"column",gap:"10px"}}>
            {["client","supplier"].includes(user.role)&&<button style={{...S.btnSm("gold"),padding:"14px",fontSize:"14px"}} onClick={()=>onNavigate("upload")}>📤 Upload New Bill</button>}
            <button style={{...S.btnSm(""),padding:"14px",fontSize:"14px"}} onClick={()=>onNavigate("bills")}>📋 View All Bills</button>
          </div>
        </div>
      </div>
    </div>
  );
}

// ── Root ──────────────────────────────────────────────────────
export default function App() {
  const [user, setUser] = useState(null);
  const [page, setPage] = useState("dashboard");
  const [viewingId, setViewingId] = useState(null);
  const [highlightId, setHighlightId] = useState(null);
  const [refreshKey, setRefreshKey] = useState(0);
  const [dark, setDark] = useState(true);

  const C = dark ? DARK : LIGHT;
  const S = makeStyles(C);

  const refresh = () => setRefreshKey(k=>k+1);
  const navigate = (pg, billId=null) => { setPage(pg); setViewingId(null); if (billId) { setHighlightId(billId); setViewingId(billId); } };

  const sharedProps = { S, C };

  if (!user) return (
    <div style={S.app}>
      <style>{`*{margin:0;padding:0;box-sizing:border-box}`}</style>
      <LoginPage onLogin={setUser} dark={dark} onToggleTheme={()=>setDark(d=>!d)} />
    </div>
  );

  const navPages = ["dashboard","bills",...(["client","supplier"].includes(user.role)?["upload"]:[])];

  return (
    <div style={S.app}>
      <style>{`*{margin:0;padding:0;box-sizing:border-box}button:hover{opacity:.84}input:focus,textarea:focus{outline:none;border-color:${C.gold}!important}`}</style>
      <nav style={S.nav}>
        <span style={S.navBrand}>📋 ExpenseTrack</span>
        <div style={{display:"flex",gap:"8px"}}>
          {navPages.map(p=>(
            <button key={p} style={{...S.btnSm(page===p?"gold":""),textTransform:"capitalize"}} onClick={()=>{setPage(p);setViewingId(null)}}>{p}</button>
          ))}
        </div>
        <div style={{display:"flex",alignItems:"center",gap:"12px"}}>
          <ThemeToggle dark={dark} onToggle={()=>setDark(d=>!d)} S={S} />
          <NotifBell user={user} onNavigate={navigate} tick={refreshKey} S={S} C={C} />
          <span style={{fontSize:"13px",color:C.muted}}>{user.name}</span>
          <span style={S.badge("gold")}>{user.role}</span>
          <button style={S.btnSm("")} onClick={()=>setUser(null)}>Sign Out</button>
        </div>
      </nav>
      <main style={S.main}>
        {viewingId ? (
          <BillDetail billId={viewingId} user={user} onBack={()=>setViewingId(null)} onUpdate={refresh} {...sharedProps} />
        ) : page==="dashboard" ? (
          <Dashboard user={user} onNavigate={navigate} refreshKey={refreshKey} {...sharedProps} />
        ) : page==="upload" ? (
          <UploadBill user={user} onBillSubmitted={()=>{refresh();setPage("bills");}} {...sharedProps} />
        ) : (
          <BillsList user={user} onViewBill={id=>setViewingId(id)} refreshKey={refreshKey} highlightId={highlightId} {...sharedProps} />
        )}
      </main>
    </div>
  );
}
