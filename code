function getApprovalChain(amount) {
  const c = ["accounts"];
  if (amount > THRESHOLDS.manager) c.push("manager");
  if (amount > THRESHOLDS.md)      c.push("md");
  return c;
}
function getChainLabel(amount) {
  const a = parseFloat(amount)||0;
  if (a > THRESHOLDS.md)      return "Accounts → Manager → MD";
  if (a > THRESHOLDS.manager) return "Accounts → Manager";
  return "Accounts only";
}

