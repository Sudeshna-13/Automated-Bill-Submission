                    <td style={S.td}><span style={S.badge("")}>{b.category}</span></td>
                    <td style={{...S.td,fontSize:"13px"}}>{b.submittedByName}<br/><span style={{color:C.muted,fontSize:"11px"}}>{b.submittedByCompany}</span></td>
                    <td style={S.td}>
                      <div style={{display:"flex",alignItems:"center",gap:"4px"}}>
                        {b.approvalChain.map((role,ci)=>{
                          const done=b.status==="approved"||(b.status==="pending"&&ci<b.currentStep);
                          const cur=b.status==="pending"&&ci===b.currentStep;
                          const rej=b.status==="rejected"&&ci===b.currentStep;
                          const dotC=done?C.green:cur?C.gold:rej?C.red:C.faint;
                          return (<div key={role} style={{display:"flex",alignItems:"center",gap:"4px"}}>
                            <div title={ROLE_LABEL[role]} style={{width:"10px",height:"10px",borderRadius:"50%",background:dotC,flexShrink:0}} />
