function NotifBell({ user, onNavigate, tick, S, C }) {
  const [open, setOpen] = useState(false);
  const [notifs, setNotifs] = useState([]);

  useEffect(() => {
    setNotifs(getNS().filter(n => n.toRole===user.role || n.toUserId===user.id));
  }, [user.role, tick]);

  const unread = notifs.filter(n=>!n.read).length;
  const click = n => {
    markRead(n.id);
    setNotifs(prev=>prev.map(x=>x.id===n.id?{...x,read:true}:x));
    setOpen(false);
    onNavigate("bills", n.billId);
  };

  return (
    <div style={{ position:"relative" }}>
      <button style={{ ...S.btnSm(""), padding:"7px 12px", position:"relative" }} onClick={()=>setOpen(o=>!o)}>
