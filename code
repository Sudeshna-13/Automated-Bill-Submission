async function scanBill(base64, mime) {
  const isPDF = mime === "application/pdf";
  const docBlock = isPDF
    ? { type:"document", source:{ type:"base64", media_type:"application/pdf", data: base64 } }
    : { type:"image",    source:{ type:"base64", media_type: mime,              data: base64 } };
  const promptText = isPDF
    ? `You are a strict corporate expense bill validator reading a PDF document.\n\nSTEP 1 — DOCUMENT TYPE CHECK:\nIf not a bill/invoice/receipt → respond ONLY:\n{"error":"NOT_BILL","message":"This does not appear to be a valid expense bill or invoice."}\n\nSTEP 2 — EXTRACT:\nRespond ONLY with JSON:\n{"vendor":"<name>","date":"<DD/MM/YYYY>","amount":<number>,"category":"<Fuel/Transport|Travel/Hotel|Repair/Maintenance|Courier/Logistics|Office Supplies|Utilities|Other>","gst":"<or null>","invoice_no":"<or null>","confidence":"<high|medium|low>"}`
    : `You are a strict corporate expense bill validator.\n\nSTEP 1 — BLUR CHECK: If too blurry/dark → {"error":"BLURRY","message":"Bill image is too blurry or poorly lit."}\nSTEP 2 — HANDWRITING CHECK: If handwritten → {"error":"HANDWRITTEN","message":"Handwritten bills are not accepted."}\nSTEP 3 — DOC TYPE: If not a bill → {"error":"NOT_BILL","message":"Not a valid bill."}\nSTEP 4 — EXTRACT:\n{"vendor":"<name>","date":"<DD/MM/YYYY>","amount":<number>,"category":"<Fuel/Transport|Travel/Hotel|Repair/Maintenance|Courier/Logistics|Office Supplies|Utilities|Other>","gst":"<or null>","invoice_no":"<or null>","confidence":"<high|medium|low>"}`;
  const res = await fetch("https://api.anthropic.com/v1/messages", {
    method:"POST", headers:{"Content-Type":"application/json"},
    body: JSON.stringify({ model:"claude-sonnet-4-20250514", max_tokens:1000, messages:[{ role:"user", content:[docBlock,{type:"text",text:promptText}] }] })
  });
  const data = await res.json();
  const raw = data.content?.find(b=>b.type==="text")?.text || "{}";
  try { return JSON.parse(raw.replace(/```json|```/g,"").trim()); }
  catch { return { error:"PARSE_ERROR", message:"Could not parse response." }; }
}

async function wordToBase64(file) {
  const ab = await file.arrayBuffer();
  const str = new TextDecoder("utf-8",{fatal:false}).decode(new Uint8Array(ab));
  const tags = str.match(/<w:t[^>]*>([^<]+)<\/w:t>/g) || [];
  const text = tags.map(t=>t.replace(/<[^>]+>/g,"")).join(" ") || file.name;
  const canvas = document.createElement("canvas");
  canvas.width=800; canvas.height=1100;
  const ctx = canvas.getContext("2d");
  ctx.fillStyle="#ffffff"; ctx.fillRect(0,0,800,1100);
  ctx.fillStyle="#111111"; ctx.font="15px Arial";
  let line="", y=40;
  text.split(" ").forEach(w => { const t=line+w+" "; if(ctx.measureText(t).width>760&&line){ctx.fillText(line,20,y);line=w+" ";y+=22;}else line=t; });
  ctx.fillText(line,20,y);
  return canvas.toDataURL("image/jpeg",0.9).split(",")[1];
}

