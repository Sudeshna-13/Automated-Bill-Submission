// ── Upload Bill ───────────────────────────────────────────────
function UploadBill({ user, onBillSubmitted, S, C }) {
  const [step, setStep] = useState("upload");
  const [imgPreview, setImgPreview] = useState(null);
  const [imgBase64, setImgBase64] = useState(null);
  const [imgMime, setImgMime] = useState(null);
  const [fileName, setFileName] = useState("");
  const [ocrData, setOcrData] = useState(null);
  const [ocrError, setOcrError] = useState(null);
  const [notes, setNotes] = useState("");
  const [submitErr, setSubmitErr] = useState("");
  const [dupBill, setDupBill] = useState(null);
  const [dragOver, setDragOver] = useState(false);
  const fileRef = useRef();

  const WORD_TYPES = ["application/vnd.openxmlformats-officedocument.wordprocessingml.document","application/msword"];
  const isWord = t => WORD_TYPES.includes(t);

  const handleFile = async file => {
    if (!file) return;
    const ext = "."+file.name.split(".").pop().toLowerCase();
    const allowed = ["image/jpeg","image/jpg","image/png","image/webp","image/gif","application/pdf",...WORD_TYPES];
    if (!allowed.includes(file.type) && ![".jpg",".jpeg",".png",".webp",".gif",".pdf",".doc",".docx"].includes(ext)) { setOcrError("Unsupported format."); return; }
    setOcrError(null); setFileName(file.name);
    if (isWord(file.type)||ext===".doc"||ext===".docx") {
      setStep("converting");
      try { const b64=await wordToBase64(file); setImgPreview("data:image/jpeg;base64,"+b64); setImgBase64(b64); setImgMime("image/jpeg"); setStep("upload"); }
      catch { setOcrError("Could not read Word file."); setStep("upload"); }
      return;
    }
    const reader = new FileReader();
    reader.onload = e => { const d=e.target.result; setImgPreview(d); setImgBase64(d.split(",")[1]); setImgMime(file.type); setStep("upload"); };
    reader.readAsDataURL(file);
  };

  const checkDuplicate = r => {
    const inVendor=(r.vendor||"").trim().toLowerCase(), inAmount=parseFloat(r.amount)||0, inDate=(r.date||"").trim(), inInvoice=(r.invoice_no||"").trim().toLowerCase();
    return getBills().find(b => {
      const bVendor=(b.vendor||"").trim().toLowerCase(), bAmount=parseFloat(b.amount)||0, bDate=(b.date||"").trim(), bInvoice=(b.invoiceNo||"").trim().toLowerCase();
      if (inInvoice&&bInvoice) return bInvoice===inInvoice&&bAmount===inAmount;
      return bVendor===inVendor&&bAmount===inAmount&&bDate===inDate;
    }) || null;
  };

  const analyze = async () => {
    if (!imgBase64) return;
    setStep("analyzing"); setOcrError(null);
    try {
      const r = await scanBill(imgBase64, imgMime||"image/jpeg");
      if (r.error==="BLURRY"||r.error==="HANDWRITTEN"||r.error==="NOT_BILL") { setOcrError(r.message); setStep("upload"); setImgPreview(null); setImgBase64(null); return; }
      if (!r.error) { const dup=checkDuplicate(r); if (dup) { setDupBill(dup); setStep("upload"); setImgPreview(null); setImgBase64(null); return; } }
      setOcrData(r.error?null:r); setStep("form");
    } catch { setOcrData(null); setStep("form"); }
  };

  const submit = () => {
    if (!ocrData?.amount||!ocrData?.vendor||!ocrData?.category) { setSubmitErr("Required fields missing."); return; }
    setStep("submitting");
    const amount=parseFloat(ocrData.amount), chain=getApprovalChain(amount);
    const bill = { id:genId(), submittedBy:user.id, submittedByName:user.name, submittedByCompany:user.company, vendor:ocrData.vendor, date:ocrData.date||new Date().toLocaleDateString("en-IN"), amount, category:ocrData.category, gst:ocrData.gst||null, invoiceNo:ocrData.invoice_no||null, notes, imagePreview:imgPreview, fileName, status:"pending", approvalChain:chain, currentStep:0, timeline:[{action:"submitted",by:user.name,role:user.role,timestamp:new Date().toISOString(),comment:`Bill submitted. ₹${amount.toLocaleString("en-IN")} | ${ocrData.category} | Chain: ${chain.map(r=>ROLE_LABEL[r]).join(" → ")}`}], createdAt:new Date().toISOString(), ocrConfidence:ocrData.confidence||"low" };
    const bills=getBills(); bills.unshift(bill); saveBills(bills);
    pushN(chain[0], `🧾 New bill from ${user.name} (${user.company}): ₹${amount.toLocaleString("en-IN")} | ${ocrData.category} — needs your approval.`, bill.id);
    setTimeout(()=>{ setStep("done"); onBillSubmitted(); }, 600);
  };

  const reset = () => { setStep("upload"); setImgPreview(null); setImgBase64(null); setOcrData(null); setOcrError(null); setNotes(""); setSubmitErr(""); setFileName(""); setDupBill(null); };

  if (step==="done") return (
    <div style={{...S.card,textAlign:"center",padding:"64px 40px"}}>
      <div style={{fontSize:"52px",marginBottom:"16px"}}>✅</div>
      <h2 style={{color:C.green,marginBottom:"10px"}}>Bill Submitted Successfully</h2>
      <p style={{color:C.muted,marginBottom:"6px"}}><strong style={{color:C.gold}}>Accounts Dept</strong> has been notified.</p>
      <button style={{...S.btnSm("gold"),marginTop:"28px",padding:"12px 32px"}} onClick={reset}>Submit Another Bill</button>
    </div>
  );

  if (["analyzing","converting","submitting"].includes(step)) return (
    <div style={{...S.card,textAlign:"center",padding:"64px 40px"}}>
      <div style={{fontSize:"48px",marginBottom:"16px"}}>{step==="analyzing"?"🔍":step==="converting"?"📄":"⏳"}</div>
      <h2 style={{color:C.gold,marginBottom:"8px"}}>{step==="analyzing"?"Scanning Bill with AI…":step==="converting"?"Converting Word Document…":"Submitting…"}</h2>
      <p style={{color:C.muted}}>{step==="analyzing"?"Checking quality, detecting handwriting, extracting details…":"Please wait…"}</p>
    </div>
  );

  return (
    <div>
      <h1 style={S.pageTitle}>Upload Expense Bill</h1>
      <p style={S.pageSub}>Accepted: JPG · PNG · WebP · GIF · PDF · DOC · DOCX &nbsp;|&nbsp; ⚠️ Printed bills only</p>
      <div style={{ display:"grid", gridTemplateColumns:step==="form"?"1fr 1fr":"1fr", gap:"24px", maxWidth:step==="form"?"100%":"580px" }}>
        <div style={S.card}>
          <h3 style={{color:C.gold,fontSize:"15px",marginBottom:"18px"}}>📎 Bill Document</h3>
          {ocrError && !dupBill && <div style={{whiteSpace:"pre-line",...S.alert("error")}}>{ocrError}</div>}
          {dupBill && (
            <div style={{background:`${C.red}10`,border:`1px solid ${C.red}40`,borderRadius:"4px",padding:"20px",marginBottom:"16px"}}>
              <div style={{display:"flex",alignItems:"center",gap:"10px",marginBottom:"14px"}}>
                <span style={{fontSize:"28px"}}>🚫</span>
                <div><div style={{fontSize:"15px",fontWeight:"700",color:C.red}}>Duplicate Bill — Cannot Be Uploaded</div><div style={{fontSize:"12px",color:C.muted,marginTop:"2px"}}>This bill already exists in the system</div></div>
              </div>
              <div style={{background:C.bg,borderRadius:"3px",padding:"14px",fontSize:"13px"}}>
                <div style={{display:"grid",gridTemplateColumns:"1fr 1fr",gap:"8px"}}>
                  {[["Existing Bill ID",dupBill.id],["Vendor",dupBill.vendor],["Amount",`₹${parseFloat(dupBill.amount).toLocaleString("en-IN")}`],["Date",dupBill.date],["Status",dupBill.status.toUpperCase()],["Category",dupBill.category]].map(([k,v])=>(
